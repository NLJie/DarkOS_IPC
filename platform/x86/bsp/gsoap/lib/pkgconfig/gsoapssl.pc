prefix=/home/nlj/workspace1/P000_rk3576_zs/project_root/platform/x86/bsp/gsoap
exec_prefix=${prefix}
libdir=${exec_prefix}/lib
includedir=${prefix}/include

Name: GSoap
Description: SOAP C Web Services with SSL, ZLIB, DOM
Version: 2.8.131
Requires:
Libs: -L${libdir} -lgsoapssl
Libs.private: -L/home/nlj/workspace1/P000_rk3576_zs/project_root/platform/x86/bsp/openssl/lib -lssl -lcrypto -lz -lm
Cflags:  -I/home/nlj/workspace1/P000_rk3576_zs/project_root/platform/x86/bsp/openssl/include -DWITH_OPENSSL -DWITH_GZIP -DWITH_DOM -I${includedir}
