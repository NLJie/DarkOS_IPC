{
  "device_name": "rk3576_cam_v1",

  "log": {
    "dir":          "./log",
    "level":        "debug",
    "max_size_mb":  1,
    "max_backups":  3,
    "console":      true,
    "timestamp_ms": false
  },

  "cameras": [
    {
      "interface":    "mipi",
      "dev_path":     "/dev/video0",
      "mipi_lanes":   4,
      "sensor":       "imx415",
      "width":        3840,
      "height":       2160,
      "fps":          30.0,
      "pixel_format": 0
    }
  ],

  "paths": {
    "data_dir":  "/userdata/pg_camera",
    "temp_dir":  "/tmp/pg_camera",
    "media_dir": "/mnt/sdcard/media"
  },

  "ai": {
    "model_path": "/userdata/models/yolov8n_rk3576.rknn",
    "threshold":  0.45
  }
}
